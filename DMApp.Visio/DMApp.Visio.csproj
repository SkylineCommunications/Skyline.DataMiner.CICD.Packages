<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net48;net10.0</TargetFrameworks>
    <AssemblyName>Skyline.DataMiner.CICD.DMApp.Visio</AssemblyName>
    <RootNamespace>Skyline.DataMiner.CICD.DMApp.Visio</RootNamespace>
    <Description>
      Library providing methods to convert Skyline Visio Repositories into DataMiner Application Packages (.DMApp) files.
      Code Entry Point: var builder = AppPackageCreatorForVisio.Factory.FromRepository(logCollector, repositoryPath, packageName, packageVersion);
    </Description>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\DMApp.Common\DMApp.Common.csproj" />
  </ItemGroup>

</Project>
